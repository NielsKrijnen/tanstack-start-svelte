{
  "name": "tanstack-svelte-router",
  "version": "0.0.1",
  "description": "Modern and scalable routing for Svelte applications",
  "author": "Niels Krijnen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NielsKrijnen/tanstack-start-svelte",
    "directory": "packages/svelte-router"
  },
  "keywords": [
    "svelte",
    "location",
    "router",
    "routing",
    "async",
    "async router",
    "typescript"
  ],
  "scripts": {},
  "type": "module",
  "types": "dist/esm/index.d.ts",
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.js",
  "exports": {
    ".": {
      "svelte": {
        "types": "./dist/source/index.d.ts",
        "development": "./dist/source/index.dev.jsx",
        "default": "./dist/source/index.jsx"
      },
      "import": {
        "types": "./dist/esm/index.d.ts",
        "development": "./dist/esm/index.dev.js",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "development": "./dist/cjs/index.dev.cjs",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./ssr/server": {
      "solid": {
        "types": "./dist/source/ssr/server.d.ts",
        "default": "./dist/source/ssr/server.js"
      },
      "import": {
        "types": "./dist/esm/ssr/server.d.ts",
        "default": "./dist/esm/ssr/server.js"
      },
      "require": {
        "types": "./dist/cjs/ssr/server.d.cts",
        "default": "./dist/cjs/ssr/server.cjs"
      }
    },
    "./ssr/client": {
      "solid": {
        "types": "./dist/source/ssr/client.d.ts",
        "default": "./dist/source/ssr/client.js"
      },
      "import": {
        "types": "./dist/esm/ssr/client.d.ts",
        "default": "./dist/esm/ssr/client.js"
      },
      "require": {
        "types": "./dist/cjs/ssr/client.d.cts",
        "default": "./dist/cjs/ssr/client.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "skills",
    "bin",
    "!skills/_artifacts"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "dependencies": {
    "@tanstack/history": "^1.162.0",
    "@tanstack/router-core": "^1.171.13",
    "isbot": "^5.1.44"
  },
  "devDependencies": {
    "@types/node": ">=20"
  },
  "peerDependencies": {
    "svelte": ">=5.3.0"
  }
}
